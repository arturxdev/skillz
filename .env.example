# Root .env for local dev. Copy to .env and fill.
# .env is gitignored — safe for secrets.
#
# Single source of truth. Propagate to targets with:
#   bun run sync:dev-vars       → packages/api/.dev.vars (for `wrangler dev`)
#   bun run sync:worker-secrets → Cloudflare Workers (for production)
#
# The API URL is also baked into compiled CLI binaries at build time by
# packages/cli/build.ts, which reads this file directly.

# --- CLI (build-time + runtime) ---
SKILLZ_API_URL=https://skillz-api.arturo8gll.workers.dev

# --- API (Cloudflare Workers secrets + wrangler dev) ---
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
RESEND_API_KEY=re_xxx
TOKEN_SIGNING_SECRET=generate-with-openssl-rand-hex-32
